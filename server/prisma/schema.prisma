generator client {
  provider = "prisma-client-js"
}

// Local PostgreSQL — no Docker required.
// Connection via DATABASE_URL in server/.env
// Default: postgresql://postgres:Admin%40123@localhost:5432/ai_tracker?schema=public
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  MANAGER
}

enum WebsiteStatus {
  ONLINE
  DOWN
  DEGRADED
  UNKNOWN
}

enum IssueCategory {
  BUG
  FEEDBACK
  SUGGESTION
  IMPROVEMENT
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  IN_REVIEW
  IN_PROGRESS
  WAITING_FOR_CLIENT
  RESOLVED
  CLOSED
}

enum ActivityType {
  CREATED
  UPDATED
  ASSIGNED
  STATUS_CHANGED
  SEVERITY_CHANGED
  COMMENT
  RESPONSE
  RESOLVED
}

enum NotificationType {
  ISSUE_RESOLVED
  ISSUE_ASSIGNED
  ISSUE_UPDATED
  ISSUE_COMMENT
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String
  passwordHash String
  role         Role
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  websites     Website[]
  issues       Issue[]        @relation("IssueCreator")
  assigned     Issue[]        @relation("IssueAssignee")
  comments     Comment[]
  activities   ActivityLog[]
  notifications Notification[]
  attachments  Attachment[]
}

model Website {
  id            String        @id @default(cuid())
  name          String
  url           String
  status        WebsiteStatus @default(UNKNOWN)
  lastCheckedAt DateTime      @default(now())
  clientId      String
  client        User          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  issues        Issue[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([clientId])
}

model Issue {
  id          String         @id @default(cuid())
  title       String
  description String
  category    IssueCategory
  severity    IssueSeverity  @default(MEDIUM)
  status      IssueStatus    @default(OPEN)
  websiteId   String
  website     Website        @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User           @relation("IssueCreator", fields: [createdById], references: [id])
  assigneeId  String?
  assignee    User?          @relation("IssueAssignee", fields: [assigneeId], references: [id])
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  comments    Comment[]
  activities  ActivityLog[]
  notifications Notification[]
  attachments Attachment[]

  @@index([websiteId])
  @@index([createdById])
  @@index([assigneeId])
  @@index([status])
}

model Comment {
  id               String   @id @default(cuid())
  body             String
  isManagerResponse Boolean @default(false)
  issueId          String
  issue            Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  authorId         String
  author           User     @relation(fields: [authorId], references: [id])
  createdAt        DateTime @default(now())

  @@index([issueId])
}

model ActivityLog {
  id        String       @id @default(cuid())
  type      ActivityType
  message   String
  metadata  Json?
  issueId   String
  issue     Issue        @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actorId   String
  actor     User         @relation(fields: [actorId], references: [id])
  createdAt DateTime     @default(now())

  @@index([issueId])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  message   String
  readAt    DateTime?
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  issueId   String?
  issue     Issue?           @relation(fields: [issueId], references: [id], onDelete: SetNull)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([readAt])
}

model Attachment {
  id           String   @id @default(cuid())
  filename     String
  mimeType     String
  size         Int
  url          String
  issueId      String
  issue        Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([issueId])
}
