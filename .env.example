# Server
PORT=3001
NODE_ENV=development

# Local PostgreSQL (no Docker)
# Password contains @ — URL-encoded as %40 in connection string
DATABASE_URL="postgresql://postgres:Admin%40123@localhost:5432/ai_tracker?schema=public"

JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_EXPIRES_IN="7d"
CLIENT_URL="http://localhost:5173"

# Optional AI (OpenAI-compatible)
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"

# Database connection reference (for manual setup)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=Admin@123
# DB_NAME=ai_tracker
